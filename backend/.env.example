# 이 파일을 복사하여 .env 로 저장한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ── 데이터베이스 ──────────────────────────────────────────────────────────
# SQLite (기본값, 개발용)
DATABASE_URL=sqlite:///./data/db.sqlite

# PostgreSQL (운영 배포 시 교체)
# DATABASE_URL=postgresql://user:password@localhost:5432/dormitory

# ── AI 서비스 ─────────────────────────────────────────────────────────────
# Gemini API 키 (https://aistudio.google.com 에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 Gemini 모델명 (GEMINI_MODEL 환경변수로 재정의 가능)
GEMINI_MODEL=gemini-2.5-flash

# ── 파일 저장 ─────────────────────────────────────────────────────────────
# 이미지 저장 디렉터리 (상대경로는 backend/ 기준)
IMAGE_STORAGE_DIR=./data/images

# ── 서버 설정 ─────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Public URL (이미지 URL 생성에 사용) ───────────────────────────────────
# 개발 환경 기본값 — 운영 배포 시 실제 도메인으로 교체
# 예: https://api.yourdomain.com
BASE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────
# 콤마로 구분하여 여러 origin 허용 가능 (Phase 2에서 main.py에 연동 예정)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com
